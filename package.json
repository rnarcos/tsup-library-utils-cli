{
  "name": "root",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "A CLI tool and examples for library maintainers using tsup",
  "type": "module",
  "engines": {
    "node": ">=20.16.0"
  },
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf .turbo node_modules",
    "clean:workspaces": "turbo clean && pnpm clean",
    "dev": "concurrently \"pnpm dev-package-json:watch\" \"turbo dev\" --names \"dev-pkg-json,dev\" --handle-input --default-input-target 1",
    "dev-package-json": "pnpm exec tsup-lib dev --workspaces packages configs",
    "dev-package-json:watch": "pnpm exec tsup-lib dev --watch --workspaces packages configs",
    "postinstall": "cd packages/cli && node src/index.js build --library --skip-validation",
    "format": "turbo format --continue -- --cache --cache-location node_modules/.cache/.prettiercache",
    "format:fix": "turbo format --continue -- --write --cache --cache-location node_modules/.cache/.prettiercache",
    "lint": "turbo lint --continue -- --cache --cache-location node_modules/.cache/.eslintcache",
    "lint:fix": "turbo lint --continue -- --fix --cache --cache-location node_modules/.cache/.eslintcache",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "release:staging:registry:up": "verdaccio -c scripts/release/staging/.verdaccio/config.yml -l 3630",
    "release:staging:publish": "pnpm publish --registry http://localhost:3630 --no-git-checks"
  },
  "devDependencies": {
    "@tsup-lib/eslint-config": "workspace:*",
    "@tsup-lib/prettier-config": "workspace:*",
    "@turbo/gen": "^1.12.4",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-turbo": "^2.5.6",
    "prettier": "^3.2.5",
    "tsup-library-utils-cli": "workspace:*",
    "turbo": "^2.3.4",
    "typescript": "^5.3.3",
    "verdaccio": "^6.1.2"
  },
  "keywords": [
    "cli",
    "library",
    "tsup",
    "build-tools",
    "maintainer",
    "monorepo"
  ]
}
