{
  "name": "@tsup-lib/eslint-config",
  "version": "0.0.1",
  "description": "ESLint configuration for tsup-library-utils-cli projects",
  "license": "MIT",
  "type": "commonjs",
  "private": false,
  "main": "src/index.ts",
  "exports": {
    "./base": {
      "require": "./src/base.js"
    },
    "./node": {
      "require": "./src/node.js"
    },
    "./react": {
      "require": "./src/react.js"
    },
    "./typescript": {
      "require": "./src/typescript.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "*.cjs",
    "cjs/**",
    "esm/**"
  ],
  "scripts": {
    "build": "tsup-lib build",
    "clean": "tsup-lib clean",
    "dev": "tsup-lib dev --library",
    "typecheck": "echo \"No TypeScript files to check\"",
    "format": "prettier --write \"src/**/*.{js,cjs,json,md}\"",
    "lint": "echo \"Config files are linted by consuming projects\""
  },
  "peerDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0 || ^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.25.0",
    "eslint-plugin-react": "^7.28.0",
    "eslint-plugin-react-hooks": "^4.3.0",
    "eslint-plugin-jsx-a11y": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@typescript-eslint/eslint-plugin": {
      "optional": true
    },
    "@typescript-eslint/parser": {
      "optional": true
    },
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "eslint-plugin-jsx-a11y": {
      "optional": true
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-jsx-a11y": "^6.9.0"
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "javascript",
    "typescript",
    "linting",
    "code-quality"
  ]
}
